# Copy this file to ".env" and fill in your own values.

# Port the API server listens on
PORT=5000

# MongoDB connection string.
# Local MongoDB example:   mongodb://127.0.0.1:27017/propspace
# MongoDB Atlas example:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/propspace
MONGO_URI=mongodb://127.0.0.1:27017/propspace

# Secret used to sign JWT tokens. Use a long, random string in production.
JWT_SECRET=change_this_to_a_long_random_secret

# How long a login token stays valid
JWT_EXPIRES_IN=7d

# Where the frontend runs (used to allow cross-origin requests)
CLIENT_URL=http://localhost:5173
